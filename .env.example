# MongoDB connection string. Never commit real credentials.
# Gameplay transactions require Atlas or a local replica set, not standalone MongoDB.
MONGODB_URI=mongodb://localhost:27017/apoc?replicaSet=rs0

# Generate locally without printing the secret: npm run auth:secret
AUTH_SECRET=

# Production only: set the canonical public URL. Trust forwarded Host headers only
# when the app is behind infrastructure you control.
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=false
